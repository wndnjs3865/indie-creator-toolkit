<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="google-site-verification" content="7xp-F4qE1Qx27nW_sm01IA66wEu_VuXkXcEw4yOhg0Q">
<title>{{ title }} — Indie Creator Toolkit</title>
<meta name="description" content="{{ description }}">
<link rel="canonical" href="{{ canonical }}">
<meta property="og:title" content="{{ title }}">
<meta property="og:description" content="{{ description }}">
<meta property="og:type" content="article">
<meta property="og:url" content="{{ canonical }}">
<meta name="twitter:card" content="summary">
<meta name="twitter:title" content="{{ title }}">
<meta name="twitter:description" content="{{ description }}">
<meta name="theme-color" content="#1e40af">
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"Article","headline":{{ title | tojson }},"description":{{ description | tojson }},"datePublished":"{{ updated }}","dateModified":"{{ updated }}","author":{"@type":"Organization","name":"Indie Creator Toolkit"},"publisher":{"@type":"Organization","name":"Indie Creator Toolkit"},"mainEntityOfPage":{"@type":"WebPage","@id":"{{ canonical }}"}}
</script>
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"BreadcrumbList","itemListElement":[{"@type":"ListItem","position":1,"name":"Indie Creator Toolkit","item":"{{ site_base }}/"},{"@type":"ListItem","position":2,"name":"{{ persona_label }}","item":"{{ site_base }}/#{{ persona }}"},{"@type":"ListItem","position":3,"name":{{ title | tojson }},"item":"{{ canonical }}"}]}
</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#fff;--bg-soft:#fafafa;--surface:#fff;--surface-2:#f8fafc;
    --text:#0a0e1a;--text-2:#374151;--text-3:#475569;--muted:#64748b;
    --border:#e6e8ee;--border-strong:#d4d8e0;
    --primary:#1e40af;--primary-2:#2563eb;--primary-3:#3b82f6;--primary-soft:#eff6ff;
    --accent:#fb923c;
    --code-bg:#f1f5f9;
    --grad-1:linear-gradient(135deg,#1e40af,#3b82f6);
    --shadow-xs:0 1px 2px rgba(15,23,42,.04);
    --shadow-sm:0 1px 3px rgba(15,23,42,.06),0 4px 12px rgba(15,23,42,.04);
    --shadow-md:0 4px 12px rgba(15,23,42,.06),0 16px 40px rgba(15,23,42,.08);
    --r-sm:8px;--r-md:12px;--r-lg:16px;
    --t-fast:140ms cubic-bezier(.4,0,.2,1);
  }
  *{box-sizing:border-box}
  html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
  body{font-family:'Inter',-apple-system,BlinkMacSystemFont,system-ui,sans-serif;background:var(--bg);color:var(--text);margin:0;line-height:1.7;-webkit-font-smoothing:antialiased;font-feature-settings:'cv02','cv03','cv11','ss01'}
  ::selection{background:var(--primary-soft);color:var(--primary)}
  a{color:var(--primary);text-decoration:none;text-underline-offset:3px}
  a:hover{text-decoration:underline;color:var(--primary-2)}

  /* READING PROGRESS BAR */
  .progress{position:fixed;top:0;left:0;height:3px;background:var(--grad-1);width:0;z-index:60;transition:width 60ms}

  /* NAV */
  .nav{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.78);backdrop-filter:saturate(180%) blur(12px);-webkit-backdrop-filter:saturate(180%) blur(12px);border-bottom:1px solid rgba(15,23,42,.06)}
  .nav-inner{max-width:1200px;margin:0 auto;padding:0 24px;display:flex;justify-content:space-between;align-items:center;height:56px}
  .brand{display:inline-flex;align-items:center;gap:8px;font-weight:700;font-size:15.5px;letter-spacing:-.01em;color:var(--text)}
  .brand-logo{width:22px;height:22px;border-radius:6px;background:var(--grad-1);color:white;display:inline-flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;box-shadow:0 2px 8px rgba(30,64,175,.3)}
  .nav-link{font-size:14px;color:var(--text-3);font-weight:500}
  .nav-link:hover{color:var(--text)}

  /* LAYOUT (TOC SIDEBAR) */
  .layout{max-width:1200px;margin:0 auto;padding:0 24px;display:grid;grid-template-columns:1fr;gap:32px}
  @media(min-width:1024px){.layout{grid-template-columns:1fr 220px;align-items:start}}
  @media(max-width:600px){.layout{padding:0 18px}}

  article{max-width:760px;justify-self:start;width:100%;padding:24px 0 48px}
  @media(min-width:1024px){article{padding-right:32px}}

  /* CRUMB */
  .crumb{font-size:13px;color:var(--muted);margin:24px 0 0}
  .crumb a{color:var(--muted)}
  .crumb a:hover{color:var(--primary)}
  .crumb span{color:var(--text)}

  /* HEAD */
  .post-head{margin:14px 0 18px}
  .post-head h1{font-size:clamp(28px,4vw,42px);line-height:1.15;letter-spacing:-.03em;font-weight:800;margin:8px 0 14px}
  .meta{color:var(--muted);font-size:13.5px;display:flex;gap:16px;flex-wrap:wrap;align-items:center;font-weight:500}
  .meta .pill-meta{display:inline-flex;align-items:center;gap:6px;padding:3px 10px;background:var(--surface-2);border:1px solid var(--border);border-radius:999px;font-size:12.5px;color:var(--text-3)}

  /* DISCLOSURE */
  .disclosure{background:#fffbeb;border:1px solid #fde68a;color:#78350f;padding:12px 16px;border-radius:var(--r-md);font-size:13.5px;line-height:1.55;margin:16px 0 32px;display:flex;align-items:flex-start;gap:10px}
  .disclosure svg{flex-shrink:0;color:#d97706;width:18px;height:18px;margin-top:1px}

  /* BODY */
  article h2{font-size:24px;letter-spacing:-.015em;font-weight:700;margin:40px 0 14px;line-height:1.25;scroll-margin-top:80px}
  article h3{font-size:19px;letter-spacing:-.01em;font-weight:700;margin:28px 0 10px;line-height:1.3;scroll-margin-top:80px}
  article p{margin:0 0 18px;font-size:17px;line-height:1.72;color:var(--text-2)}
  article ul,article ol{padding-left:1.4em;margin:0 0 18px}
  article li{margin:7px 0;font-size:17px;line-height:1.7;color:var(--text-2)}
  article strong{font-weight:600;color:var(--text)}
  article blockquote{margin:20px 0;padding:10px 18px;border-left:3px solid var(--primary);background:var(--primary-soft);border-radius:0 var(--r-md) var(--r-md) 0}
  article blockquote p{margin:0;font-size:16px;font-style:italic;color:var(--text)}
  article code{background:var(--code-bg);padding:2px 6px;border-radius:4px;font-family:'JetBrains Mono',ui-monospace,monospace;font-size:.9em}
  article pre{background:#0b1220;color:#e2e8f0;padding:18px 20px;border-radius:var(--r-md);overflow-x:auto;font-family:'JetBrains Mono',ui-monospace,monospace;font-size:13px;line-height:1.65;margin:20px 0}
  article pre code{background:transparent;padding:0;color:inherit}

  /* TABLES */
  .tablewrap{overflow-x:auto;margin:20px 0;border:1px solid var(--border);border-radius:var(--r-md);background:var(--surface);box-shadow:var(--shadow-xs);-webkit-overflow-scrolling:touch}
  article table{border-collapse:collapse;width:100%;font-size:14px;min-width:560px}
  article th,article td{padding:12px 16px;text-align:left;vertical-align:top;border-bottom:1px solid var(--border)}
  article th{background:var(--surface-2);font-weight:600;color:var(--muted);font-size:11.5px;text-transform:uppercase;letter-spacing:.06em;white-space:nowrap}
  article tr:hover td{background:rgba(239,246,255,.4)}
  article tr:last-child td{border-bottom:0}
  article td a{font-weight:500}
  article td strong a{font-weight:600;font-size:15px}

  /* SHARE BAR */
  .share{display:flex;gap:8px;margin:32px 0 24px;flex-wrap:wrap;align-items:center}
  .share-label{font-size:13px;color:var(--muted);font-weight:500;margin-right:4px}
  .share a{display:inline-flex;align-items:center;gap:6px;padding:7px 14px;background:var(--surface-2);border:1px solid var(--border);border-radius:var(--r-sm);font-size:13px;color:var(--text-3);font-weight:500;transition:background var(--t-fast),border-color var(--t-fast),color var(--t-fast)}
  .share a:hover{background:var(--primary-soft);border-color:var(--primary-3);color:var(--primary);text-decoration:none}
  .share svg{width:14px;height:14px}

  /* RELATED */
  .related{margin:40px 0 0;padding:24px;background:var(--surface-2);border:1px solid var(--border);border-radius:var(--r-md)}
  .related h3{margin:0 0 14px;font-size:13px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);font-weight:600}
  .related ul{list-style:none;padding:0;margin:0}
  .related li{padding:6px 0;font-size:15px}
  .related li a{display:inline-flex;align-items:center;gap:8px;font-weight:500}
  .related li a::before{content:'→';color:var(--muted);transition:transform var(--t-fast),color var(--t-fast)}
  .related li a:hover::before{color:var(--primary);transform:translateX(2px)}

  /* CTA */
  .article-cta{margin:36px 0 0;padding:28px;background:linear-gradient(135deg,#1e40af 0%,#3b82f6 100%);border-radius:var(--r-md);text-align:center;color:white;position:relative;overflow:hidden}
  .article-cta::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 50% 40% at 30% 30%,rgba(255,255,255,.1),transparent 60%);pointer-events:none}
  .article-cta h3{margin:0 0 6px;font-size:18px;color:white;font-weight:700}
  .article-cta p{margin:0 0 16px;color:rgba(255,255,255,.78);font-size:14px}
  .article-cta a{display:inline-block;padding:10px 22px;background:white;color:var(--text);border-radius:var(--r-sm);font-weight:600;font-size:14px;transition:transform var(--t-fast)}
  .article-cta a:hover{transform:translateY(-1px);text-decoration:none}

  /* TOC SIDEBAR */
  .toc{display:none;position:sticky;top:80px;font-size:13.5px}
  @media(min-width:1024px){.toc{display:block}}
  .toc h4{font-size:11.5px;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);font-weight:600;margin:0 0 12px}
  .toc ul{list-style:none;padding:0;margin:0}
  .toc li{margin:0}
  .toc a{display:block;padding:6px 12px;color:var(--text-3);border-left:2px solid var(--border);transition:color var(--t-fast),border-color var(--t-fast)}
  .toc a:hover{color:var(--primary);border-left-color:var(--primary-3);text-decoration:none}
  .toc a.active{color:var(--primary);border-left-color:var(--primary);font-weight:600}

  /* FOOTER */
  footer{padding:40px 0 60px;border-top:1px solid var(--border);background:var(--surface);font-size:13px;color:var(--muted);margin-top:64px}
  .foot-row{max-width:1200px;margin:0 auto;padding:0 24px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:10px}
  footer a{color:var(--muted)}
  footer a:hover{color:var(--text)}

  /* TOOL CARD — rich product showcase */
  .tool-card{display:grid;grid-template-columns:60px 1fr auto;gap:16px;align-items:center;padding:20px;background:var(--surface);border:1px solid var(--border);border-radius:var(--r-md);margin:18px 0;transition:transform 200ms cubic-bezier(.4,0,.2,1),box-shadow 200ms,border-color 200ms}
  .tool-card:hover{transform:translateY(-2px);box-shadow:var(--shadow-md);border-color:var(--primary-3)}
  .tool-card .logo{width:60px;height:60px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:26px;font-weight:800;color:white;letter-spacing:-.03em;flex-shrink:0}
  .tool-card .logo.b1{background:linear-gradient(135deg,#dc2626,#f97316)}
  .tool-card .logo.b2{background:linear-gradient(135deg,#7c3aed,#a855f7)}
  .tool-card .logo.b3{background:linear-gradient(135deg,#0891b2,#06b6d4)}
  .tool-card .logo.b4{background:linear-gradient(135deg,#16a34a,#22c55e)}
  .tool-card .logo.b5{background:linear-gradient(135deg,#1e40af,#3b82f6)}
  .tool-card .logo.b6{background:linear-gradient(135deg,#0a0e1a,#475569)}
  .tool-card .info{min-width:0}
  .tool-card .info-top{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:4px}
  .tool-card .info h3{margin:0;font-size:17px;font-weight:700;letter-spacing:-.01em}
  .tool-card .info p{margin:0 0 8px;font-size:13.5px;color:var(--text-3);line-height:1.5}
  .tool-card .stats{display:flex;gap:14px;font-size:12px;color:var(--muted);flex-wrap:wrap}
  .tool-card .stats span{display:inline-flex;align-items:center;gap:4px;white-space:nowrap}
  .tool-card .cta{display:inline-flex;align-items:center;gap:6px;align-self:center;padding:10px 18px;background:var(--text);color:white !important;border-radius:var(--r-sm);font-size:13px;font-weight:600;white-space:nowrap;transition:background var(--t-fast),transform var(--t-fast)}
  .tool-card .cta:hover{background:#1e2939;transform:translateY(-1px);text-decoration:none}
  @media(max-width:600px){.tool-card{grid-template-columns:48px 1fr;padding:16px}.tool-card .logo{width:48px;height:48px;font-size:20px;border-radius:12px}.tool-card .cta{grid-column:1/-1;justify-content:center;margin-top:8px}}

  /* BADGES */
  .badge{display:inline-flex;align-items:center;padding:2px 8px;font-size:10.5px;font-weight:700;border-radius:999px;letter-spacing:.05em;text-transform:uppercase;line-height:1.4}
  .badge-best{background:#fef3c7;color:#92400e}
  .badge-popular{background:#dbeafe;color:#1e40af}
  .badge-budget{background:#dcfce7;color:#166534}
  .badge-pro{background:#f3e8ff;color:#7e22ce}
  .badge-free{background:#e0e7ff;color:#3730a3}

  /* PROS / CONS */
  .pros-cons{display:grid;gap:14px;grid-template-columns:1fr;margin:18px 0}
  @media(min-width:640px){.pros-cons{grid-template-columns:1fr 1fr}}
  .pros,.cons{padding:18px 20px;border-radius:var(--r-md)}
  .pros{background:#f0fdf4;border:1px solid #bbf7d0}
  .cons{background:#fef2f2;border:1px solid #fecaca}
  .pros h4,.cons h4{margin:0 0 10px;font-size:11.5px;text-transform:uppercase;letter-spacing:.08em;font-weight:700;display:inline-flex;align-items:center;gap:6px}
  .pros h4{color:#166534}
  .cons h4{color:#991b1b}
  article .pros ul,article .cons ul{margin:0;padding-left:18px;font-size:14px;line-height:1.6}
  article .pros li,article .cons li{margin-bottom:4px;font-size:14px}

  /* QUICK PICK */
  .quickpick{display:flex;gap:16px;align-items:center;padding:18px 22px;background:linear-gradient(135deg,#1e40af,#3b82f6);color:white;border-radius:var(--r-md);margin:24px 0;box-shadow:var(--shadow-sm)}
  .quickpick-icon{font-size:28px;line-height:1;flex-shrink:0}
  .quickpick-content h4{margin:0 0 4px;font-size:15px;color:white;font-weight:700}
  .quickpick-content p{margin:0;font-size:14px;color:rgba(255,255,255,.88);line-height:1.5}
  .quickpick-content a{color:white;text-decoration:underline;font-weight:600}
  .quickpick-content a:hover{color:rgba(255,255,255,.85)}

  /* CHECK ICON for tables (✓/✗ pretty) */
  article td .yes{color:#16a34a;font-weight:700}
  article td .no{color:#dc2626;font-weight:700}
  article td .ok{color:#0891b2;font-weight:600;font-size:12px}

  /* Mobile */
  @media (max-width:600px){
    article p,article li{font-size:16px}
    .post-head h1{font-size:28px}
    .related,.article-cta{padding:20px}
  }
</style>
</head>
<body>
<div class="progress" id="progress"></div>

<nav class="nav">
  <div class="nav-inner">
    <a href="../" class="brand"><span class="brand-logo">I</span> Indie Creator Toolkit</a>
    <a href="../" class="nav-link">All comparisons →</a>
  </div>
</nav>

<div class="layout">
  <article>
    <nav class="crumb"><a href="../">Home</a> · <a href="../#{{ persona }}">{{ persona_label }}</a> · <span>{{ title }}</span></nav>

    <header class="post-head">
      <h1>{{ title }}</h1>
      <div class="meta">
        <span class="pill-meta">📅 Updated {{ updated }}</span>
        <span class="pill-meta">📖 {{ word_count }} words · {{ (word_count / 200) | int }} min read</span>
        <span class="pill-meta">🎯 {{ persona_label }}</span>
      </div>
    </header>

    <div class="disclosure">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="7.5 4.21 12 6.81 16.5 4.21"/><polyline points="7.5 19.79 7.5 14.6 3 12"/><polyline points="21 12 16.5 14.6 16.5 19.79"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
      <span><strong>Affiliate disclosure</strong> — Some links may earn us a commission at no extra cost to you. We only recommend tools we'd use ourselves.</span>
    </div>

    <div class="article-body">{{ body | safe }}</div>

    <div class="share">
      <span class="share-label">Share:</span>
      <a href="https://twitter.com/intent/tweet?text={{ title|urlencode }}&url={{ canonical|urlencode }}" target="_blank" rel="noopener">𝕏 Twitter</a>
      <a href="https://www.reddit.com/submit?title={{ title|urlencode }}&url={{ canonical|urlencode }}" target="_blank" rel="noopener">Reddit</a>
      <a href="https://news.ycombinator.com/submitlink?u={{ canonical|urlencode }}&t={{ title|urlencode }}" target="_blank" rel="noopener">HN</a>
    </div>

{% if related %}
    <aside class="related">
      <h3>Related comparisons</h3>
      <ul>
      {% for r in related %}<li><a href="../{{ r.slug }}/">{{ r.title }}</a></li>{% endfor %}
      </ul>
    </aside>
{% endif %}

    <div class="article-cta">
      <h3>More creator tool comparisons?</h3>
      <p>We add a fresh comparison page every day. Browse the full index.</p>
      <a href="../">See all comparisons →</a>
    </div>
  </article>

  <aside class="toc" id="toc">
    <h4>On this page</h4>
    <ul id="toc-list"></ul>
  </aside>
</div>

<footer>
  <div class="foot-row">
    <span>Indie Creator Toolkit · Updated {{ updated }}</span>
    <span><a href="../sitemap.xml">sitemap</a> · <a href="https://github.com/{{ gh_user }}/indie-creator-toolkit">github</a></span>
  </div>
</footer>

<script>
// Wrap loose tables in scrollable containers
document.querySelectorAll('article table').forEach(t => {
  if (t.parentElement.classList.contains('tablewrap')) return;
  const w = document.createElement('div');
  w.className = 'tablewrap';
  t.parentNode.insertBefore(w, t);
  w.appendChild(t);
});

// Reading progress bar
(function(){
  const bar = document.getElementById('progress');
  const article = document.querySelector('article');
  function upd(){
    const top = article.getBoundingClientRect().top;
    const h = article.offsetHeight - window.innerHeight;
    const pct = Math.min(100, Math.max(0, (-top / h) * 100));
    bar.style.width = pct + '%';
  }
  document.addEventListener('scroll', upd, {passive:true});
  upd();
})();

// Auto-build TOC from h2/h3
(function(){
  const list = document.getElementById('toc-list');
  if (!list) return;
  const heads = document.querySelectorAll('article h2, article h3');
  if (heads.length < 2) { document.getElementById('toc').style.display = 'none'; return; }
  heads.forEach((h,i) => {
    if (!h.id) h.id = 'h-' + i;
    const li = document.createElement('li');
    const a = document.createElement('a');
    a.href = '#' + h.id;
    a.textContent = h.textContent;
    if (h.tagName === 'H3') a.style.paddingLeft = '24px';
    li.appendChild(a);
    list.appendChild(li);
  });
  // Active link tracking
  const links = list.querySelectorAll('a');
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        links.forEach(l => l.classList.toggle('active', l.getAttribute('href') === '#' + e.target.id));
      }
    });
  }, { rootMargin: '-100px 0px -60% 0px' });
  heads.forEach(h => obs.observe(h));
})();
</script>
</body>
</html>
