<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="google-site-verification" content="7xp-F4qE1Qx27nW_sm01IA66wEu_VuXkXcEw4yOhg0Q">
<title>Indie Creator Toolkit — Software Comparisons for Solo Creators</title>
<meta name="description" content="Honest, free-first software comparisons for podcasters, indie game devs, screenwriters, illustrators, and newsletter writers.">
<link rel="canonical" href="{{ canonical }}">
<meta property="og:title" content="Indie Creator Toolkit">
<meta property="og:description" content="Honest, free-first software comparisons for solo creators.">
<meta property="og:type" content="website">
<meta property="og:url" content="{{ canonical }}">
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Indie Creator Toolkit",
  "url": "{{ canonical }}",
  "description": "Honest, free-first software comparisons for solo creators."
}
</script>
<style>
  body { font-family: ui-sans-serif, system-ui, sans-serif; max-width: 760px; margin: 2rem auto; padding: 0 1rem; line-height: 1.65; }
  h1 { font-size: 2.4rem; margin-bottom: 0.3rem; }
  h2 { margin-top: 2rem; font-size: 1.4rem; }
  .lede { color: #555; font-size: 1.05rem; margin-bottom: 2rem; }
  .grid a { display: block; padding: 0.6rem 0.8rem; border-bottom: 1px solid #eee; text-decoration: none; color: #0a66c2; }
  .grid a:hover { background: #f6f6f6; }
  .pill { display: inline-block; padding: 1px 8px; border-radius: 999px; background: #eef; font-size: 0.7rem; margin-left: 6px; color: #555; vertical-align: middle; }
  .pill-vs { background: #fef3c7; }
  .pill-free { background: #d1fae5; }
  footer { margin-top: 3rem; padding-top: 1rem; border-top: 1px solid #eee; color: #888; font-size: 0.85rem; }
</style>
</head>
<body>
<h1>Indie Creator Toolkit</h1>
<p class="lede">Honest software comparisons for solo creators. Free options first, paid only when worth it. Updated automatically.</p>

{% for persona in personas %}
<section id="{{ persona.id }}">
<h2>For {{ persona.label }} <span style="color:#999;font-size:0.7em;font-weight:400">({{ persona.pages | length }})</span></h2>
<div class="grid">
  {% for page in persona.pages %}<a href="{{ page.url }}">{{ page.title }}{% if page.pattern == "vs" %}<span class="pill pill-vs">vs</span>{% elif page.pattern == "free-alts" %}<span class="pill pill-free">free</span>{% else %}<span class="pill">best</span>{% endif %}</a>{% endfor %}
</div>
</section>
{% endfor %}

<footer>{{ total_pages }} pages · Updated {{ updated }} · <a href="sitemap.xml">sitemap</a></footer>
</body>
</html>
