<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta name="google-site-verification" content="7xp-F4qE1Qx27nW_sm01IA66wEu_VuXkXcEw4yOhg0Q">
<title>Indie Creator Toolkit — Software Comparisons for Solo Creators</title>
<meta name="description" content="Honest, free-first software comparisons for podcasters, indie game devs, screenwriters, illustrators, and newsletter writers. {{ total_pages }}+ comparisons, updated weekly.">
<link rel="canonical" href="{{ canonical }}">
<meta property="og:title" content="Indie Creator Toolkit — Software Comparisons for Solo Creators">
<meta property="og:description" content="Honest, free-first software comparisons for solo creators.">
<meta property="og:type" content="website">
<meta property="og:url" content="{{ canonical }}">
<meta name="twitter:card" content="summary_large_image">
<meta name="theme-color" content="#1e40af">
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"WebSite","name":"Indie Creator Toolkit","url":"{{ canonical }}","description":"Honest, free-first software comparisons for solo creators."}
</script>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#fff;--bg-mesh:#f6f8fc;--surface:#fff;--surface-2:#f8fafc;
    --text:#0a0e1a;--text-2:#475569;--muted:#64748b;
    --border:#e6e8ee;--border-strong:#d4d8e0;
    --primary:#1e40af;--primary-2:#2563eb;--primary-3:#3b82f6;--primary-soft:#eff6ff;
    --accent:#fb923c;
    --grad-1:linear-gradient(135deg,#1e40af,#3b82f6);
    --grad-text:linear-gradient(135deg,#1e40af 0%,#2563eb 60%,#3b82f6 100%);
    --shadow-xs:0 1px 2px rgba(15,23,42,.04);
    --shadow-sm:0 1px 3px rgba(15,23,42,.06),0 4px 12px rgba(15,23,42,.04);
    --shadow-md:0 4px 12px rgba(15,23,42,.06),0 16px 40px rgba(15,23,42,.08);
    --r-sm:8px;--r-md:12px;--r-lg:16px;--r-xl:24px;
    --t-fast:140ms cubic-bezier(.4,0,.2,1);
    --t-med:220ms cubic-bezier(.4,0,.2,1);
  }
  *{box-sizing:border-box}
  html{scroll-behavior:smooth;-webkit-text-size-adjust:100%}
  body{font-family:'Inter',-apple-system,BlinkMacSystemFont,system-ui,sans-serif;background:var(--bg);color:var(--text);margin:0;line-height:1.6;-webkit-font-smoothing:antialiased;font-feature-settings:'cv02','cv03','cv11','ss01'}
  ::selection{background:var(--primary-soft);color:var(--primary)}
  a{color:var(--primary);text-decoration:none}
  a:hover{color:var(--primary-2)}
  .container{max-width:1200px;margin:0 auto;padding:0 24px}
  @media (max-width:600px){.container{padding:0 18px}}

  /* NAV */
  .nav{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.78);backdrop-filter:saturate(180%) blur(12px);-webkit-backdrop-filter:saturate(180%) blur(12px);border-bottom:1px solid rgba(15,23,42,.06)}
  .nav-inner{display:flex;align-items:center;justify-content:space-between;padding:14px 0}
  .brand{display:inline-flex;align-items:center;gap:8px;font-weight:700;font-size:16px;letter-spacing:-.01em;color:var(--text)}
  .brand-logo{width:22px;height:22px;border-radius:6px;background:var(--grad-1);color:white;display:inline-flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;box-shadow:0 2px 8px rgba(30,64,175,.3)}
  .nav-links{display:none;gap:24px;align-items:center;font-size:14px;font-weight:500}
  @media(min-width:880px){.nav-links{display:flex}}
  .nav-links a{color:var(--text-2);transition:color var(--t-fast)}
  .nav-links a:hover{color:var(--text)}

  /* HERO */
  .hero{position:relative;padding:88px 0 64px;text-align:center;overflow:hidden}
  .hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 50% at 50% -10%,rgba(59,130,246,.13),transparent 60%),radial-gradient(ellipse 50% 35% at 85% 25%,rgba(251,146,60,.10),transparent 60%),radial-gradient(ellipse 55% 35% at 15% 30%,rgba(99,102,241,.08),transparent 60%);pointer-events:none;z-index:-1}
  .hero::after{content:'';position:absolute;inset:0;background-image:radial-gradient(rgba(15,23,42,.04) 1px,transparent 1px);background-size:24px 24px;-webkit-mask-image:radial-gradient(ellipse 60% 60% at 50% 0%,black 30%,transparent 80%);mask-image:radial-gradient(ellipse 60% 60% at 50% 0%,black 30%,transparent 80%);pointer-events:none;z-index:-1}
  @media(max-width:600px){.hero{padding:56px 0 40px}}
  .eyebrow{display:inline-flex;align-items:center;gap:8px;padding:6px 14px;background:rgba(255,255,255,.7);backdrop-filter:blur(8px);border:1px solid var(--border);border-radius:999px;font-size:13px;font-weight:500;color:var(--text-2);margin-bottom:24px;box-shadow:var(--shadow-xs)}
  .eyebrow .dot{color:var(--accent)}
  .hero h1{font-size:clamp(36px,6vw,64px);line-height:1.05;letter-spacing:-.035em;font-weight:800;margin:0 0 18px;max-width:880px;margin-left:auto;margin-right:auto}
  .hero h1 .grad{background:var(--grad-text);-webkit-background-clip:text;background-clip:text;color:transparent}
  .hero .lede{font-size:clamp(16px,1.8vw,19px);color:var(--text-2);max-width:600px;margin:0 auto 32px;line-height:1.55}
  .hero-stats{display:inline-flex;align-items:center;gap:14px;font-size:13.5px;color:var(--muted);background:var(--surface);border:1px solid var(--border);padding:8px 16px;border-radius:999px;box-shadow:var(--shadow-xs)}
  .hero-stats strong{color:var(--text)}
  .hero-stats .sep{color:var(--border-strong)}

  /* PERSONA SECTIONS */
  .personas{padding:24px 0 48px}
  .persona-block{margin:48px 0}
  .persona-head{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:18px;gap:12px;flex-wrap:wrap}
  .persona-head h2{font-size:clamp(22px,2.4vw,28px);letter-spacing:-.02em;font-weight:700;margin:0;display:inline-flex;align-items:center;gap:10px}
  .persona-icon{width:32px;height:32px;border-radius:8px;background:var(--primary-soft);color:var(--primary);display:inline-flex;align-items:center;justify-content:center;font-size:16px}
  .persona-head .pcount{color:var(--muted);font-size:13.5px;font-weight:500}

  .grid{display:grid;gap:14px;grid-template-columns:1fr}
  @media(min-width:560px){.grid{grid-template-columns:1fr 1fr}}
  @media(min-width:920px){.grid{grid-template-columns:repeat(3,1fr)}}

  .ctile{display:flex;flex-direction:column;justify-content:space-between;background:var(--surface);border:1px solid var(--border);border-radius:var(--r-md);padding:18px 20px;transition:border-color var(--t-fast),transform var(--t-fast),box-shadow var(--t-fast);min-height:124px;text-decoration:none}
  .ctile:hover{border-color:var(--primary-3);box-shadow:var(--shadow-md);transform:translateY(-2px);text-decoration:none}
  .ctile-title{font-size:15.5px;font-weight:600;color:var(--text);line-height:1.4;margin:0 0 16px;letter-spacing:-.005em}
  .ctile-meta{display:flex;justify-content:space-between;align-items:center}
  .pill{display:inline-block;padding:3px 10px;border-radius:999px;font-size:11px;font-weight:600;letter-spacing:.04em;text-transform:uppercase}
  .pill-best{background:var(--primary-soft);color:var(--primary)}
  .pill-vs{background:#fef3c7;color:#92400e}
  .pill-free{background:#dcfce7;color:#15803d}
  .ctile-arrow{color:var(--muted);font-size:16px;transition:transform var(--t-fast),color var(--t-fast)}
  .ctile:hover .ctile-arrow{color:var(--primary);transform:translateX(2px)}

  /* CTA */
  .cta{margin:64px 0 0;padding:48px 32px;background:linear-gradient(135deg,#1e40af 0%,#2563eb 60%,#3b82f6 100%);border-radius:var(--r-xl);text-align:center;color:white;position:relative;overflow:hidden}
  .cta::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 50% 40% at 30% 30%,rgba(255,255,255,.15),transparent 60%),radial-gradient(ellipse 50% 40% at 70% 70%,rgba(251,146,60,.18),transparent 60%);pointer-events:none}
  .cta h3{font-size:clamp(22px,3vw,32px);letter-spacing:-.02em;margin:0 0 10px;font-weight:800;color:white}
  .cta p{color:rgba(255,255,255,.78);font-size:16px;margin:0 0 24px;max-width:520px;margin-left:auto;margin-right:auto}
  .cta a.btn{display:inline-block;padding:13px 28px;background:white;color:var(--text);border-radius:var(--r-md);font-weight:600;font-size:15px;transition:transform var(--t-fast)}
  .cta a.btn:hover{transform:translateY(-2px);text-decoration:none}

  footer{margin-top:64px;padding:40px 0 56px;border-top:1px solid var(--border);background:var(--surface);font-size:13.5px;color:var(--muted)}
  .foot-row{display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;align-items:center}
  footer a{color:var(--muted);transition:color var(--t-fast)}
  footer a:hover{color:var(--text)}
</style>
</head>
<body>

<nav class="nav">
  <div class="container nav-inner">
    <span class="brand"><span class="brand-logo">I</span> Indie Creator Toolkit</span>
    <div class="nav-links">
      {% for persona in personas[:5] %}
      <a href="#{{ persona.id }}">{{ persona.label }}</a>
      {% endfor %}
    </div>
  </div>
</nav>

<header class="hero">
  <div class="container">
    <div class="eyebrow"><span class="dot">●</span> {{ total_pages }} comparisons · Updated automatically</div>
    <h1>Tools for solo creators,<br><span class="grad">honestly compared.</span></h1>
    <p class="lede">Free-first software comparisons for podcasters, indie game devs, screenwriters, illustrators, and newsletter writers. No bloat. No bias. Just data.</p>
    <div class="hero-stats">
      <strong>{{ total_pages }}</strong> comparisons <span class="sep">·</span>
      <strong>25+</strong> tools tracked <span class="sep">·</span>
      Updated weekly
    </div>
  </div>
</header>

<main class="container personas">
{% for persona in personas %}
<section class="persona-block" id="{{ persona.id }}">
  <div class="persona-head">
    <h2>
      <span class="persona-icon">
      {%- if persona.id == "solo-podcasters" %}🎙{% elif persona.id == "indie-game-devs" %}🎮{% elif persona.id == "screenwriters" %}✍{% elif persona.id == "illustrators" %}🎨{% elif persona.id == "newsletter-writers" %}📧{% elif persona.id == "audiobook-narrators" %}🎧{% elif persona.id == "indie-filmmakers" %}🎬{% elif persona.id == "music-producers" %}🎼{% elif persona.id == "comparison" %}⚖{% elif persona.id == "free-alternatives" %}🆓{% else %}★{% endif -%}
      </span>
      For {{ persona.label }}
    </h2>
    <span class="pcount">{{ persona.pages | length }} comparison{{ '' if persona.pages|length == 1 else 's' }}</span>
  </div>
  <div class="grid">
    {% for page in persona.pages %}
    <a href="{{ page.url }}" class="ctile">
      <span class="ctile-title">{{ page.title }}</span>
      <span class="ctile-meta">
        {% if page.pattern == "vs" %}<span class="pill pill-vs">vs</span>
        {% elif page.pattern == "free-alts" %}<span class="pill pill-free">free</span>
        {% else %}<span class="pill pill-best">best</span>{% endif %}
        <span class="ctile-arrow">→</span>
      </span>
    </a>
    {% endfor %}
  </div>
</section>
{% endfor %}

<div class="cta">
  <h3>New comparison every day.</h3>
  <p>We add a fresh comparison page each morning, automatically. Bookmark, follow on GitHub, or browse the full sitemap.</p>
  <a href="sitemap.xml" class="btn">View sitemap →</a>
</div>
</main>

<footer>
  <div class="container foot-row">
    <span>{{ total_pages }} pages · Updated {{ updated }}</span>
    <span><a href="sitemap.xml">sitemap</a> · <a href="https://github.com/{{ "wndnjs3865" }}/indie-creator-toolkit">github</a></span>
  </div>
</footer>

</body>
</html>
